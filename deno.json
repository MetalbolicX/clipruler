{
  "name": "@clipruler/clipruler",
  "version": "0.1.0",
  "exports": "./main.ts",
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0",
    "@std/path": "jsr:@std/path@^1.0",
    "@std/fs": "jsr:@std/fs@^1.0",
    "@std/async": "jsr:@std/async@^1.0",
    "@std/crypto": "jsr:@std/crypto@^1.0",
    "@std/encoding": "jsr:@std/encoding@^1.0",
    "@std/uuid": "jsr:@std/uuid@^1.0",
    "@std/testing": "jsr:@std/testing@^1.0",
    "@std/assert": "jsr:@std/assert@^1.0",
    "@std/log": "jsr:@std/log@^1.0",
    "@std/bytes": "jsr:@std/bytes@^1.0",
    "@std/streams": "jsr:@std/streams@^1.0",
    "@std/semver": "jsr:@std/semver@^1.0"
  },
  "tasks": {
    "check": "deno check main.ts src/**/*.ts",
    "test": "deno test --allow-read --allow-write --allow-run --allow-net --allow-env=CLIPRULER_CLIPBOARD_TESTS,CLIPRULER_NET_TESTS,HOME,USER,OS,DISPLAY,WAYLAND_DISPLAY,XDG_DATA_HOME,XDG_CONFIG_HOME,XDG_CACHE_HOME,XDG_RUNTIME_DIR",
    "test:discovery": "CLIPRULER_NET_TESTS=1 deno test --allow-net --allow-env=CLIPRULER_NET_TESTS --filter \"discovery\" tests/integration/discovery_udp_test.ts",
    "test:net": "CLIPRULER_NET_TESTS=1 deno test --allow-read --allow-write --allow-run --allow-net --allow-env=CLIPRULER_NET_TESTS tests/integration/transport_tls_test.ts",
    "test:clipboard": "CLIPRULER_CLIPBOARD_TESTS=1 deno test --allow-read --allow-write --allow-run --allow-env=CLIPRULER_CLIPBOARD_TESTS,DISPLAY,WAYLAND_DISPLAY tests/integration/clipboard_smoke_test.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "smoke": "deno run --allow-read main.ts --help",
    "desktop": "deno run -A main.ts -- desktop",
    "build:linux": "deno compile --output dist/clipruler-linux-x64 --allow-env=CLIPRULER_DEVICE_NAME,OS,HOME,XDG_CONFIG_HOME,XDG_DATA_HOME,XDG_CACHE_HOME,WAYLAND_DISPLAY,DISPLAY --allow-sys=hostname --allow-read=$HOME/.config/clipruler,$HOME/.local/share/clipruler,$HOME/.cache/clipruler --allow-write=$HOME/.config/clipruler,$HOME/.local/share/clipruler,$HOME/.cache/clipruler --allow-net main.ts"
  },
  "unstable": ["net"],
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "fmt": { "indentWidth": 2, "lineWidth": 100 },
  "lint": {
    "rules": { "tags": ["recommended", "strict"] }
  }
}
